# Snowball mobile env example
# B person can copy these values into the mobile app environment file.

# Backend URL
# Important:
# - localhost works only when the app runs on the same machine as the backend.
# - For a physical Android phone, replace this with an ngrok or LAN URL.
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# Solana public config
EXPO_PUBLIC_SOLANA_NETWORK=devnet
EXPO_PUBLIC_PROGRAM_ID=2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss
EXPO_PUBLIC_CAMPAIGN_ID=campaign-rtx-5080-demo
EXPO_PUBLIC_PROGRAM_EXPLORER=https://explorer.solana.com/address/2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss?cluster=devnet

# Feature flags
EXPO_PUBLIC_LIFI_ENABLED=true
EXPO_PUBLIC_ELEVENLABS_ENABLED=true

# Do NOT put backend-only secrets in mobile env.
# Do NOT put ELEVENLABS_API_KEY here.
# Do NOT put LIFI_API_KEY here.
# Do NOT put Solana private keys here.
