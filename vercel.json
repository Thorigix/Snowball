{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run check && npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps && npm --prefix backend install",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/campaign/:id", "destination": "/campaign/[id].html" },
    { "source": "/join/:id", "destination": "/join/[id].html" },
    { "source": "/funding/:id", "destination": "/funding/[id].html" },
    { "source": "/delivery/:id", "destination": "/delivery/[id].html" }
  ]
}
