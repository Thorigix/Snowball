PORT=3001

# Snowball backend public config
SOLANA_NETWORK=devnet
PROGRAM_ID=2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss
CAMPAIGN_ID=campaign-rtx-5080-demo
PROGRAM_EXPLORER=https://explorer.solana.com/address/2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss?cluster=devnet

# Backend URL
# Use localhost for local browser testing.
# Use ngrok/LAN URL for mobile phone testing.
BACKEND_URL=http://localhost:3001

# ElevenLabs
# Optional for demo. If empty, /api/elevenlabs/summary-audio returns JSON fallback.
# If filled, the endpoint returns audio/mpeg.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# LI.FI
# Optional. If empty or if live quote params are missing, backend returns fallback route.
LIFI_API_KEY=
LIFI_INTEGRATOR=snowball

# Devnet payer
# Use ANCHOR_WALLET locally and ANCHOR_WALLET_JSON on Vercel.
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
ANCHOR_WALLET_JSON=
