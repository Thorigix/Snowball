PORT=3001

# Snowball public Solana config
SOLANA_NETWORK=devnet
PROGRAM_ID=2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss
CAMPAIGN_ID=campaign-rtx-5080-demo
PROGRAM_EXPLORER=https://explorer.solana.com/address/2CvWVs51VW8mKGX8nk1PujUeFWFEPMZU1mi86vAdXcss?cluster=devnet

# Backend URL
# For local backend testing, keep this as localhost.
# For physical phone testing, replace it with an ngrok or LAN URL.
BACKEND_URL=http://localhost:3001

# ElevenLabs server-side config
# Do not expose these values to the mobile app.
# Leave empty if using JSON fallback instead of real audio.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# LI.FI server-side config
# API key is optional. The backend still returns a safe fallback without it.
LIFI_API_KEY=
LIFI_INTEGRATOR=snowball

# Anchor / devnet demo script config
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
